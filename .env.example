# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — find it in Supabase Dashboard → Settings → API
# Use the base URL only: https://<ref>.supabase.co  (no /rest/v1/ suffix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable (anon) key — safe to expose to the browser, SELECT-only via RLS
# Supabase Dashboard → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Service role key — bypasses RLS, used only in server-side admin routes
# Supabase Dashboard → Settings → API → Project API keys → service_role (secret)
# NEVER prefix with NEXT_PUBLIC_ — must never reach the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key or secret-key-from-supabase-dashboard

# ─── Admin Auth ────────────────────────────────────────────────────────────────
# Secret used to sign HMAC-SHA256 session tokens — keep this long and random
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Session lifetime in seconds (default 28800 = 8 hours / one working shift)
ADMIN_SESSION_MAX_AGE=28800

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Used for OTP login codes and customer confirmation emails.
# If left blank the app runs fine — OTP codes print to the server console
# and confirmation emails are logged instead of sent.
# Get a key at https://resend.com
RESEND_API_KEY=
