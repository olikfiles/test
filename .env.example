# ─── Admin Portal ─────────────────────────────────────────────
# Root admin credentials (server-side only — never sent to the browser)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_before_deploy

# Session duration in seconds (28800 = 8 hours / one working shift)
ADMIN_SESSION_MAX_AGE=28800

# ─── Supabase Database ────────────────────────────────────────
# Required for fetching/updating orders and reservations
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ─── Email Notifications (Resend) ─────────────────────────────
# Required for sending confirmation emails to customers.
# If left blank, the system will mock emails and print them to the console.
RESEND_API_KEY=